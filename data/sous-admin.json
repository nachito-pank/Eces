{
  "actualites": [
    {
      "id": "act_001",
      "titre": "Rentrée Académique 2025-2026",
      "contenu": "La rentrée académique 2025-2026 est officiellement fixée au lundi 06 octobre 2025. Les inscriptions sont ouvertes dans toutes les filières. Munissez-vous de votre dernier diplôme (BAC), d'une photocopie de l'acte de naissance en couleur et d'une enveloppe kaki A4.",
      "datePublication": "2025-09-01T08:00:00Z",
      "auteur": "Administration ECES",
      "statut": "publie"
    },
    {
      "id": "act_002",
      "titre": "Journées Portes Ouvertes ECES",
      "contenu": "L'ECES ouvre ses portes les 20 et 21 septembre 2025 de 8h à 16h. Venez découvrir nos filières, rencontrer les enseignants et obtenir des informations sur les conditions d'inscription et les frais de formation.",
      "datePublication": "2025-09-05T10:00:00Z",
      "auteur": "Direction ECES",
      "statut": "publie"
    },
    {
      "id": "act_003",
      "titre": "Remise des Diplômes Promotion 2024",
      "contenu": "La cérémonie de remise des diplômes de la promotion 2024 se tiendra le 28 septembre 2025 à partir de 10h. Tous les lauréats sont priés de confirmer leur présence auprès du secrétariat avant le 15 septembre.",
      "datePublication": "2025-09-03T09:00:00Z",
      "auteur": "Secrétariat Général",
      "statut": "publie"
    },
    {
      "id": "act_004",
      "titre": "Nouveau Programme : Data Science",
      "contenu": "L'ECES est fière d'annoncer l'ouverture de la filière Data Science pour la rentrée 2025-2026. Cette formation de pointe prépare les étudiants aux métiers du numérique et de l'analyse de données. Places limitées, inscrivez-vous rapidement.",
      "datePublication": "2025-08-20T14:00:00Z",
      "auteur": "Direction Pédagogique",
      "statut": "publie"
    },
    {
      "id": "act_005",
      "titre": "Partenariat avec des Entreprises du Congo",
      "contenu": "L'ECES a signé des conventions de stage et d'emploi avec 12 nouvelles entreprises partenaires à Brazzaville. Les étudiants des filières Comptabilité, RH, Marketing et Génie Informatique bénéficieront en priorité de ces opportunités professionnelles.",
      "datePublication": "2025-08-15T11:00:00Z",
      "auteur": "Service des Relations Entreprises",
      "statut": "publie"
    },
    {
      "id": "act_006",
      "titre": "Calendrier des Examens Semestriels - Session 1",
      "contenu": "Le calendrier des examens de la première session est disponible au secrétariat et affiché dans chaque département. Les étudiants sont invités à vérifier leurs salles et horaires. Toute réclamation doit être déposée 48h avant le début des examens.",
      "datePublication": "2025-11-10T08:30:00Z",
      "auteur": "Service de Scolarité",
      "statut": "publie"
    },
    {
      "id": "act_007",
      "titre": "Séminaire sur l'Entrepreneuriat Jeune",
      "contenu": "Un séminaire sur l'entrepreneuriat sera organisé le 15 novembre 2025 dans la grande salle de l'ECES. Intervenant principal : M. Ibouanga, directeur général d'une PME de référence à Brazzaville. Ouvert à tous les étudiants, participation gratuite.",
      "datePublication": "2025-10-25T09:00:00Z",
      "auteur": "Club Entrepreneuriat ECES",
      "statut": "publie"
    },
    {
      "id": "act_008",
      "titre": "Résultats du Concours d'Excellence 2025",
      "contenu": "Félicitations aux lauréats du concours d'excellence ECES 2025 ! Les 10 meilleurs étudiants toutes filières confondues bénéficieront d'une réduction de 50% sur les frais de scolarité du prochain semestre. La liste complète est affichée au tableau d'honneur.",
      "datePublication": "2025-10-01T12:00:00Z",
      "auteur": "Direction ECES",
      "statut": "publie"
    },
    {
      "id": "act_009",
      "titre": "Atelier de Préparation aux Stages",
      "contenu": "Le service des stages organise un atelier de rédaction de CV et de préparation aux entretiens professionnels le 5 novembre 2025. Cet atelier s'adresse particulièrement aux étudiants de L3, L+1 et Master. Inscription obligatoire avant le 1er novembre.",
      "datePublication": "2025-10-20T10:00:00Z",
      "auteur": "Service des Stages",
      "statut": "publie"
    },
    {
      "id": "act_010",
      "titre": "Fermeture Exceptionnelle - Fête Nationale",
      "contenu": "L'établissement sera fermé le 15 août 2025 à l'occasion de la Fête Nationale. Les cours reprendront normalement le lundi 18 août. Les étudiants ayant des soutenances prévues ce jour sont priés de contacter le secrétariat pour reporter leur date.",
      "datePublication": "2025-08-10T08:00:00Z",
      "auteur": "Administration ECES",
      "statut": "publie"
    }
  ],

